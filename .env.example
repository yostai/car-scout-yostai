# Car Scout - Environment Variables
# Copy this file to .env and fill in your values

# Firecrawl API key (from firecrawl.dev)
FIRECRAWL_API_KEY=fc-your_key_here

# Gmail SMTP — use a Gmail App Password, NOT your regular Gmail password
# To create an app password: Google Account → Security → 2-Step Verification → App passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your_gmail_app_password_here

# Admin password — used to protect the config update endpoint and web admin panel
ADMIN_PASSWORD=choose_a_strong_password_here

# Flask port (default: 5000)
PORT=5000
